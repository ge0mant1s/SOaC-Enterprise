{
  "name": "soac-harness",
  "version": "1.0.0",
  "description": "SOaC validation harness — schema & cross-reference checks for CLAW playbooks, detection rules, policies, and package metadata",
  "bin": {
    "soac-harness": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "validate": "ts-node src/index.ts",
    "test": "ts-node src/index.ts validate --path ../../../packages --level 2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.6.2",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0"
}
