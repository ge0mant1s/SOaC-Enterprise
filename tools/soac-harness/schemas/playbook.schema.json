{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://soacframe.io/schemas/playbook.schema.json",
  "title": "CLAW Playbook v1",
  "description": "JSON Schema for playbook.yaml \u2014 claw.soac.io/v1 Playbook",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "claw.soac.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "Playbook"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": [
        "trigger",
        "steps"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "trigger": {
          "type": "object",
          "required": [
            "source"
          ],
          "additionalProperties": true
        },
        "inputs": {
          "type": "array"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "action"
            ],
            "additionalProperties": true
          },
          "minItems": 1
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Playbook output definitions (array of output objects)"
        },
        "rollback": {
          "type": "object",
          "description": "Rollback configuration with steps",
          "additionalProperties": true
        },
        "governance": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}