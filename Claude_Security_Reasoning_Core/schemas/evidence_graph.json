{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SOaC Evidence Graph",
  "type": "object",
  "properties": {
    "metadata": { "type": "object" },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["user", "host", "ip", "token", "process"] }
        }
      }
    },
    "signals": { "type": "array" }
  }
}