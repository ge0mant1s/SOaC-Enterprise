{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SOaC Evidence Graph",
  "type": "object",
  "properties": {
    "package_id": {
      "type": "string"
    },
    "incident_id": {
      "type": "string"
    },
    "time_window": {
      "type": "object",
      "properties": {
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ]
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "description": "e.g., Entra, AWS CloudTrail, Salesforce, SAP SAL"
          },
          "signal_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "principal": {
            "type": "string",
            "description": "user/role/service principal"
          },
          "ip": {
            "type": "string"
          },
          "artifact": {
            "type": "string",
            "description": "token_id, access_key_id, role_arn, report_id, etc."
          },
          "summary": {
            "type": "string"
          },
          "raw": {
            "type": "object",
            "description": "raw fields from SIEM event, sanitized"
          }
        },
        "required": [
          "source",
          "signal_id",
          "severity",
          "summary"
        ]
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "allow_auto_containment": {
          "type": "boolean"
        },
        "change_window": {
          "type": "string"
        },
        "known_admins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approved_automation_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "package_id",
    "time_window",
    "signals"
  ]
}