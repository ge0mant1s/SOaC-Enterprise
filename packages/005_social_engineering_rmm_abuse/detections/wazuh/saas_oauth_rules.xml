<!-- SOaC pkg-005: SaaS OAuth & Integration Risk Defense Rules -->
<group name="soac,saas,oauth,integration,">

  <rule id="100401" level="13">
    <if_sid>87801</if_sid>
    <field name="azure.operationName">Consent to application</field>
    <field name="azure.properties.modifiedProperties" type="pcre2">(?:Mail\.ReadWrite|Files\.ReadWrite\.All|Directory\.ReadWrite\.All|full_access_as_app)</field>
    <description>SOaC: High-risk OAuth consent grant detected - dangerous scope permissions</description>
    <mitre>
      <id>T1098.003</id>
      <id>T1566.002</id>
    </mitre>
    <options>no_full_log</options>
    <group>saas,oauth,consent,</group>
  </rule>

  <rule id="100402" level="14">
    <if_sid>87801</if_sid>
    <field name="azure.operationName">Consent to application</field>
    <field name="azure.properties.modifiedProperties" type="pcre2">(?:IsVerifiedPublisher:\s*false|publisherVerificationStatus:\s*unverified)</field>
    <description>SOaC: Consent grant to unverified publisher - possible consent phishing attack</description>
    <mitre>
      <id>T1566.002</id>
      <id>T1528</id>
    </mitre>
    <options>no_full_log</options>
    <group>saas,oauth,phishing,</group>
  </rule>

  <rule id="100403" level="12">
    <if_sid>87801</if_sid>
    <field name="azure.operationName" type="pcre2">(?:Add application|Update application|Update service principal credentials)</field>
    <field name="azure.properties.modifiedProperties" type="pcre2">(?:passwordCredential|keyCredential)</field>
    <frequency>3</frequency>
    <timeframe>3600</timeframe>
    <description>SOaC: Rapid application credential modifications - possible integration abuse</description>
    <mitre>
      <id>T1098.003</id>
    </mitre>
    <options>no_full_log</options>
    <group>saas,integration,credential,</group>
  </rule>

  <rule id="100404" level="13">
    <if_sid>87802</if_sid>
    <field name="o365.Operation" type="pcre2">(?:FileDownloaded|MailItemsAccessed)</field>
    <field name="o365.UserAgent" type="pcre2">(?:python-requests|axios|curl|Go-http-client)</field>
    <frequency>50</frequency>
    <timeframe>3600</timeframe>
    <description>SOaC: Bulk SaaS data access via API client - possible exfiltration</description>
    <mitre>
      <id>T1567</id>
      <id>T1530</id>
    </mitre>
    <options>no_full_log</options>
    <group>saas,exfiltration,api,</group>
  </rule>

</group>
