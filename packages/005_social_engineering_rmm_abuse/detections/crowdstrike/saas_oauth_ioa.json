{
  "ioa_definitions": [
    {
      "name": "Illicit OAuth Consent Grant",
      "description": "Detects consent grants to unverified applications with high-risk scopes",
      "severity": "critical",
      "platform": "cloud",
      "tactic": "Initial Access",
      "technique": "T1566.002",
      "disposition": "DETECT_AND_ALERT",
      "pattern": {
        "type": "cloud_api_activity",
        "conditions": {
          "event_type": "consent_grant",
          "publisher_verified": false,
          "dangerous_scopes": ["Mail.ReadWrite", "Files.ReadWrite.All", "Directory.ReadWrite.All"]
        }
      },
      "response_actions": ["revoke_consent", "alert_soc", "block_app"]
    },
    {
      "name": "SaaS Bulk Data Exfiltration",
      "description": "Detects anomalous bulk data access via API clients",
      "severity": "high",
      "platform": "cloud",
      "tactic": "Exfiltration",
      "technique": "T1567",
      "disposition": "DETECT_AND_ALERT",
      "pattern": {
        "type": "data_access",
        "conditions": {
          "api_client_user_agent": true,
          "access_count_per_hour": {"gte": 100},
          "data_types": ["files", "emails", "sharepoint"]
        }
      },
      "response_actions": ["throttle_api", "alert_soc", "revoke_token"]
    }
  ],
  "metadata": {"package": "pkg-005", "version": "1.0.0", "last_updated": "2025-03-28"}
}
