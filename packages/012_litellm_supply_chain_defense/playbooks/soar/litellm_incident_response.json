{
  "playbook": {
    "id": "soar-012-001",
    "name": "LiteLLM Supply Chain - Full Incident Response",
    "version": "1.0.0",
    "description": "Vendor-agnostic SOAR playbook for responding to LiteLLM supply chain compromise. Compatible with Palo Alto XSOAR, Splunk SOAR, IBM QRadar SOAR, and similar platforms.",
    "severity": "CRITICAL",
    "mitre_attack": ["T1195.002", "T1552.001", "T1528", "T1078.004"],
    "tags": ["supply-chain", "litellm", "credential-theft", "automated-response"],
    "trigger": {
      "type": "alert",
      "sources": ["SIEM", "EDR", "DNS_MONITORING"],
      "conditions": [
        {"field": "alert.category", "operator": "contains", "value": "supply_chain"},
        {"field": "alert.severity", "operator": "in", "values": ["critical", "high"]}
      ]
    },
    "inputs": [
      {"name": "alert_id", "type": "string", "required": true},
      {"name": "affected_host", "type": "string", "required": true},
      {"name": "affected_user", "type": "string", "required": true}
    ],
    "phases": [
      {
        "name": "Triage",
        "steps": [
          {
            "id": 1,
            "action": "ENRICH_ALERT",
            "description": "Gather full context from SIEM and EDR",
            "integrations": ["sentinel", "crowdstrike"],
            "parameters": {"query_window": "24h", "include_related_alerts": true},
            "output": "enriched_alert"
          },
          {
            "id": 2,
            "action": "CHECK_PACKAGE_INTEGRITY",
            "description": "Verify litellm package hash against known good",
            "parameters": {
              "package": "litellm",
              "verify_source": "https://pypi.org/pypi/litellm/json",
              "check_methods": ["sha256", "file_size", "signature"]
            },
            "output": "integrity_result"
          },
          {
            "id": 3,
            "action": "DECISION",
            "description": "Determine if compromise is confirmed",
            "conditions": [
              {"if": "integrity_result.tampered == true", "then": "PROCEED_CONTAINMENT"},
              {"if": "enriched_alert.confidence >= 0.8", "then": "PROCEED_CONTAINMENT"},
              {"else": "ESCALATE_TO_ANALYST"}
            ]
          }
        ]
      },
      {
        "name": "Containment",
        "steps": [
          {
            "id": 4,
            "action": "ISOLATE_HOST",
            "description": "Network isolate the compromised system",
            "integrations": ["crowdstrike", "sentinelone", "carbon_black"],
            "parameters": {"isolation_level": "full", "allow_forensics": true}
          },
          {
            "id": 5,
            "action": "REVOKE_SESSIONS",
            "description": "Revoke all active sessions for the affected user",
            "integrations": ["azure_ad", "okta", "google_workspace"],
            "parameters": {"scope": "all_sessions", "include_service_principals": true}
          },
          {
            "id": 6,
            "action": "BLOCK_IOCS",
            "description": "Block known C2 domains and IPs at perimeter",
            "integrations": ["firewall", "proxy", "dns"],
            "parameters": {
              "indicators": [
                {"type": "domain", "value": "*.litellm-telemetry.io"},
                {"type": "domain", "value": "*.ai-proxy-cdn.com"},
                {"type": "domain", "value": "*.ml-analytics-pipe.net"}
              ],
              "action": "block",
              "duration": "permanent"
            }
          }
        ]
      },
      {
        "name": "Eradication",
        "steps": [
          {
            "id": 7,
            "action": "ROTATE_CREDENTIALS",
            "description": "Rotate all exposed API keys and secrets",
            "integrations": ["azure_keyvault", "aws_secrets_manager", "hashicorp_vault"],
            "parameters": {
              "credential_types": ["api_key", "service_principal", "database_password"],
              "scope": "all_exposed",
              "generate_new": true
            }
          },
          {
            "id": 8,
            "action": "REMOVE_PERSISTENCE",
            "description": "Remove .pth files and reinstall clean packages",
            "parameters": {
              "remove_files": ["*.pth in site-packages (non-standard)"],
              "reinstall_packages": ["litellm", "openai", "anthropic"],
              "source": "pypi_verified",
              "pin_versions": true
            }
          }
        ]
      },
      {
        "name": "Recovery",
        "steps": [
          {
            "id": 9,
            "action": "VERIFY_CLEAN",
            "description": "Run integrity checks on restored system",
            "parameters": {"full_scan": true, "verify_network": true}
          },
          {
            "id": 10,
            "action": "RESTORE_ACCESS",
            "description": "Lift network containment and restore services",
            "conditions": [{"requires": "VERIFY_CLEAN.passed == true"}]
          },
          {
            "id": 11,
            "action": "CREATE_REPORT",
            "description": "Generate incident report with timeline",
            "output": "incident_report"
          }
        ]
      }
    ],
    "outputs": [
      {"name": "incident_report", "type": "document"},
      {"name": "rotated_credentials_count", "type": "integer"},
      {"name": "containment_duration", "type": "duration"}
    ]
  }
}
