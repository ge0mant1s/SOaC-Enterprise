| comment("LiteLLM Supply Chain Attack - Comprehensive Hunt Query")
| comment("MITRE ATT&CK: T1195.002, T1552.001, T1528, T1078.004")
| comment("Hunts for supply chain compromise indicators across endpoint and network data")

`sysmon` EventCode=11
| search TargetFilename="*site-packages*" TargetFilename="*.pth"
| where NOT match(TargetFilename, "easy-install\.pth|setuptools\.pth|distutils-precedence\.pth")
| eval risk_score=if(match(TargetFilename, "litellm"), 100, 80)
| eval mitre_technique="T1546.016"
| eval alert_name="Suspicious .pth file in Python site-packages"
| stats count as pth_events, values(TargetFilename) as filenames,
        values(Computer) as hosts, max(risk_score) as max_risk
    by Image, User
| append [
    search index=proxy sourcetype=stream:http
    | search dest IN ("*.litellm-telemetry.io", "*.ai-proxy-cdn.com", "*.ml-analytics-pipe.net")
    | eval risk_score=95
    | eval mitre_technique="T1071.001"
    | eval alert_name="C2 communication to known supply chain domains"
    | stats count as network_events, values(dest) as c2_domains,
            values(src_ip) as source_ips, max(risk_score) as max_risk
        by user
]
| append [
    search index=main sourcetype=linux_secure OR sourcetype=wineventlog
    | search (CommandLine="*AWS_SECRET_ACCESS_KEY*" OR CommandLine="*OPENAI_API_KEY*"
             OR CommandLine="*LITELLM_MASTER_KEY*" OR CommandLine="*DATABASE_URL*")
    | where match(Image, "python")
    | eval risk_score=85
    | eval mitre_technique="T1552.001"
    | eval alert_name="Credential environment variable harvesting"
    | stats count as cred_events, values(CommandLine) as commands,
            values(Computer) as hosts, max(risk_score) as max_risk
        by User
]
| eval overall_risk=case(
    max_risk>=95, "CRITICAL",
    max_risk>=80, "HIGH",
    max_risk>=60, "MEDIUM",
    true(), "LOW")
| sort -max_risk
