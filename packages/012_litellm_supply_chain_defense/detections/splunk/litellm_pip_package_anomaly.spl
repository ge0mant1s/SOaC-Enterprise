| comment("LiteLLM Package Integrity Anomaly Detection")
| comment("Detects unexpected pip install operations for litellm or related packages")
| comment("MITRE ATT&CK: T1195.002")

index=main sourcetype=sysmon EventCode=1
| search (CommandLine="*pip install*litellm*" OR CommandLine="*pip3 install*litellm*"
         OR CommandLine="*pip install*-e*" OR CommandLine="*setup.py*install*")
| eval is_dev_install=if(match(CommandLine, "\-e|\-\-editable|setup\.py"), 1, 0)
| eval is_force=if(match(CommandLine, "\-\-force|\-\-no-deps|\-\-upgrade"), 1, 0)
| eval package_source=case(
    match(CommandLine, "git\+"), "git_repo",
    match(CommandLine, "http://|https://"), "url_direct",
    match(CommandLine, "\.whl|\.tar\.gz"), "local_file",
    true(), "pypi_registry")
| eval risk_score=case(
    package_source="url_direct", 90,
    package_source="local_file" AND is_force=1, 85,
    is_dev_install=1, 70,
    is_force=1, 60,
    true(), 30)
| eval risk_level=case(risk_score>=80, "CRITICAL", risk_score>=60, "HIGH", risk_score>=40, "MEDIUM", true(), "LOW")
| table _time, Computer, User, CommandLine, package_source, is_dev_install, is_force, risk_score, risk_level
| sort -risk_score
