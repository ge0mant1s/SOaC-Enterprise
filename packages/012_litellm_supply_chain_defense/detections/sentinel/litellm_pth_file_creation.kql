// LiteLLM Supply Chain - .pth File Persistence Detection
// Detects creation of Python .pth files in site-packages directories
// which auto-execute on Python interpreter startup.
// MITRE ATT&CK: T1546.016, T1195.002
DeviceFileEvents
| where Timestamp > ago(7d)
| where ActionType in ("FileCreated", "FileModified")
| where FolderPath has "site-packages"
| where FileName endswith ".pth"
| where FileName !in ("easy-install.pth", "setuptools.pth", "distutils-precedence.pth")
| extend FileContent = iff(FileSize < 10240, "Small file - possible code loader", "Large file - investigate")
| project Timestamp, DeviceName, FileName, FolderPath, FileSize,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          InitiatingProcessAccountName, SHA256
| extend AlertSeverity = "Critical",
         MitreAttack = "T1546.016, T1195.002",
         Description = strcat("Suspicious .pth file created: ", FileName, " in ", FolderPath)
| sort by Timestamp desc
