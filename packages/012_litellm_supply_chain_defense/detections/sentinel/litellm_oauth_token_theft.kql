// LiteLLM Supply Chain - OAuth Token Theft Detection
// Detects unauthorized access to OAuth tokens and API keys stored
// in cloud service configurations (Azure Key Vault, AWS SSM, etc.)
// MITRE ATT&CK: T1528, T1078.004
let timeWindow = 24h;
// Azure AD sign-in anomalies from compromised service principals
let suspiciousSignIns = SigninLogs
| where TimeGenerated > ago(timeWindow)
| where AppDisplayName has_any ("litellm", "openai", "anthropic", "huggingface")
| where ResultType == 0 // Successful sign-ins
| summarize SignInCount = count(),
            UniqueIPs = dcount(IPAddress),
            UniqueLocations = dcount(Location),
            IPList = make_set(IPAddress, 10)
    by UserPrincipalName, AppDisplayName, bin(TimeGenerated, 1h)
| where UniqueIPs > 2 or SignInCount > 50;
// Key Vault access anomalies
let keyVaultAccess = AzureDiagnostics
| where TimeGenerated > ago(timeWindow)
| where ResourceType == "VAULTS"
| where OperationName has_any ("SecretGet", "SecretList", "KeyGet")
| where ResultType == "Success"
| summarize AccessCount = count(),
            UniqueCallers = dcount(CallerIPAddress),
            Operations = make_set(OperationName, 10)
    by Resource, CallerIPAddress, bin(TimeGenerated, 1h)
| where AccessCount > 20 or UniqueCallers > 3;
// Combine for correlation
suspiciousSignIns
| join kind=fullouter (keyVaultAccess) on $left.UserPrincipalName == $right.CallerIPAddress
| extend AlertSeverity = "High",
         MitreAttack = "T1528, T1078.004",
         Description = "Potential OAuth token theft via compromised AI service integration"
| sort by TimeGenerated desc
