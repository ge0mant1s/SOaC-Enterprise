// LiteLLM Supply Chain - Credential Exfiltration Detection
// Detects outbound data exfiltration patterns from Python processes
// accessing cloud API keys and transmitting to external endpoints.
// MITRE ATT&CK: T1552.001, T1567, T1041
let suspiciousDomains = dynamic([
    "litellm-telemetry.io", "ai-proxy-cdn.com", "ml-analytics-pipe.net"
]);
let credentialEnvVars = dynamic([
    "AWS_SECRET_ACCESS_KEY", "AZURE_CLIENT_SECRET", "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY", "LITELLM_MASTER_KEY", "DATABASE_URL",
    "HUGGINGFACE_API_KEY", "GOOGLE_API_KEY"
]);
// Stage 1: Detect credential environment variable access
let credentialAccess = DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName in~ ("python.exe", "python3.exe", "python", "python3")
| where ProcessCommandLine has_any (credentialEnvVars)
| project CredAccessTime = Timestamp, DeviceId, DeviceName,
          AccountName, ProcessCommandLine, InitiatingProcessFileName;
// Stage 2: Correlate with outbound network connections
let suspiciousNetwork = DeviceNetworkEvents
| where Timestamp > ago(24h)
| where RemoteUrl has_any (suspiciousDomains)
    or (InitiatingProcessFileName in~ ("python.exe", "python3.exe", "python", "python3")
        and RemotePort in (443, 80, 8443)
        and RemoteIPType == "Public")
| project NetTime = Timestamp, DeviceId, DeviceName,
          RemoteUrl, RemoteIP, RemotePort,
          InitiatingProcessFileName, InitiatingProcessCommandLine;
// Stage 3: Correlate — credential access followed by network exfil within 5 minutes
credentialAccess
| join kind=inner (suspiciousNetwork) on DeviceId
| where NetTime between (CredAccessTime .. (CredAccessTime + 5m))
| project-away DeviceId1, DeviceName1
| extend AlertSeverity = "Critical",
         MitreAttack = "T1552.001, T1567",
         Description = "Credential harvesting followed by network exfiltration detected"
| sort by CredAccessTime desc
