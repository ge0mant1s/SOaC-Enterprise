{
  "ioa_definitions": [
    {
      "id": "ioa-012-001",
      "name": "LiteLLM Supply Chain - .pth Persistence",
      "description": "Detects creation of Python .pth files in site-packages directories that auto-execute code on Python startup",
      "severity": "CRITICAL",
      "mitre_attack": ["T1546.016", "T1195.002"],
      "platform": ["Windows", "Linux", "macOS"],
      "type": "CustomIOA",
      "rule_group": "SOaC Supply Chain Defense",
      "disposition": "DETECT_AND_ALERT",
      "conditions": {
        "file_operations": {
          "event_types": ["FileCreate", "FileWrite"],
          "file_path_pattern": "**/site-packages/**/*.pth",
          "exclusions": [
            "**/easy-install.pth",
            "**/setuptools.pth",
            "**/distutils-precedence.pth"
          ]
        },
        "process_context": {
          "parent_process": ["python*", "pip*", "setup.py"],
          "command_line_contains_any": ["install", "setup", "build"]
        }
      },
      "response_actions": [
        "QUARANTINE_FILE",
        "ALERT_SOC",
        "CAPTURE_PROCESS_TREE"
      ]
    },
    {
      "id": "ioa-012-002",
      "name": "LiteLLM Supply Chain - Credential Harvesting",
      "description": "Detects Python processes systematically reading cloud API credentials from environment variables",
      "severity": "HIGH",
      "mitre_attack": ["T1552.001", "T1528"],
      "platform": ["Windows", "Linux", "macOS"],
      "type": "CustomIOA",
      "rule_group": "SOaC Supply Chain Defense",
      "disposition": "DETECT_AND_ALERT",
      "conditions": {
        "process_operations": {
          "process_name": ["python*", "python3*"],
          "command_line_contains_any": [
            "AWS_SECRET_ACCESS_KEY",
            "AZURE_CLIENT_SECRET",
            "OPENAI_API_KEY",
            "ANTHROPIC_API_KEY",
            "LITELLM_MASTER_KEY"
          ]
        },
        "network_context": {
          "outbound_connection_within": "5m",
          "remote_port_any": [443, 80, 8443]
        }
      },
      "response_actions": [
        "ALERT_SOC",
        "NETWORK_CONTAIN",
        "CAPTURE_MEMORY"
      ]
    },
    {
      "id": "ioa-012-003",
      "name": "LiteLLM Supply Chain - C2 Communication",
      "description": "Detects outbound connections to known supply chain C2 infrastructure",
      "severity": "CRITICAL",
      "mitre_attack": ["T1071.001", "T1567"],
      "platform": ["Windows", "Linux", "macOS"],
      "type": "CustomIOA",
      "rule_group": "SOaC Supply Chain Defense",
      "disposition": "DETECT_AND_BLOCK",
      "conditions": {
        "dns_operations": {
          "query_contains_any": [
            "litellm-telemetry.io",
            "ai-proxy-cdn.com",
            "ml-analytics-pipe.net",
            "litellm-update",
            "proxy-health-check"
          ]
        },
        "network_operations": {
          "remote_domain_any": [
            "*.litellm-telemetry.io",
            "*.ai-proxy-cdn.com",
            "*.ml-analytics-pipe.net"
          ]
        }
      },
      "response_actions": [
        "BLOCK_CONNECTION",
        "ALERT_SOC",
        "NETWORK_CONTAIN"
      ]
    }
  ],
  "metadata": {
    "package_id": "pkg-012",
    "version": "1.0.0",
    "author": "SOaC Community",
    "created": "2026-03-28",
    "falcon_api_compatible": true
  }
}
