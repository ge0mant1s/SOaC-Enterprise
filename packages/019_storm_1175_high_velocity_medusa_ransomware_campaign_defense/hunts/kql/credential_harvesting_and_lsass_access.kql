DeviceProcessEvents | where Timestamp > ago(7d) | where ProcessCommandLine has_any ("lsass", "sekurlsa", "mimikatz", "procdump", "comsvcs.dll") or (FileName =~ "rundll32.exe" and ProcessCommandLine contains "comsvcs.dll") | where InitiatingProcessParentFileName in~ ("w3wp.exe", "java.exe", "powershell.exe", "cmd.exe")