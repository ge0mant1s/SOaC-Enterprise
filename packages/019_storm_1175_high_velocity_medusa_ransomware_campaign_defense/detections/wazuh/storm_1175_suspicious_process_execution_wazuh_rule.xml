<rule id="100019" level="12">
  <if_group>sysmon_event1</if_group>
  <field name="win.eventdata.parentImage">w3wp.exe|java.exe|tomcat.exe|nginx.exe</field>
  <field name="win.eventdata.image">cmd.exe|powershell.exe|bash|wscript.exe|rundll32.exe</field>
  <field name="win.eventdata.commandLine">whoami|net user|systeminfo|vssadmin delete|bcdedit|wbadmin delete</field>
  <description>Storm-1175 suspicious process execution from web application</description>
  <mitre>
    <id>T1059</id>
  </mitre>
</rule>