DeviceNetworkEvents | where Timestamp > ago(1h) | where RemotePort in (445, 135, 3389, 5985, 5986, 22) | where InitiatingProcessFileName in~ ('cmd.exe', 'powershell.exe', 'psexec.exe', 'wmic.exe', 'schtasks.exe', 'winrs.exe', 'ssh.exe') | join kind=inner (DeviceProcessEvents | where ProcessCommandLine contains_any ('psexec', 'wmic /node', 'schtasks /s', 'winrm', 'invoke-command', 'enter-pssession')) on DeviceName | project Timestamp, DeviceName, RemoteIP, RemotePort, InitiatingProcessFileName, ProcessCommandLine