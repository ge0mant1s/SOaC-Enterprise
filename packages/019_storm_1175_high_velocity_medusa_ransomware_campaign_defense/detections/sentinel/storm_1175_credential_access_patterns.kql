DeviceProcessEvents | where Timestamp > ago(1h) | where ProcessCommandLine contains_any ('lsass', 'sam', 'security', 'ntds.dit', 'mimikatz', 'procdump', 'comsvcs.dll', 'MiniDump', 'sekurlsa', 'kerberos', 'wdigest', 'tspkg') or FileName in~ ('procdump.exe', 'procdump64.exe', 'sqldumper.exe', 'createdump.exe') | where InitiatingProcessFileName in~ ('w3wp.exe', 'java.exe', 'tomcat.exe', 'cmd.exe', 'powershell.exe') | project Timestamp, DeviceName, FileName, ProcessCommandLine, InitiatingProcessFileName