DeviceFileEvents | where Timestamp > ago(1h) | where (FileName endswith '.medusa' or FileName endswith '.encrypted' or FileName endswith '.locked') or (FileName contains_any ('ransom', 'decrypt', 'recovery') and FileName endswith_any ('.txt', '.html', '.hta')) | union (DeviceProcessEvents | where ProcessCommandLine contains_any ('vssadmin delete shadows', 'wbadmin delete catalog', 'bcdedit /set recoveryenabled no', 'wmic shadowcopy delete', 'cipher /w:', 'sdelete', 'medusa', 'encrypt', 'ransom') | where Timestamp > ago(1h)) | project Timestamp, DeviceName, ActionType, FileName, FolderPath, ProcessCommandLine