<!-- SOaC pkg-006: EvilProxy Credential Harvest Rules -->
<group name="soac,evilproxy,credential,phishing,">

  <rule id="100501" level="14">
    <if_sid>87801</if_sid>
    <field name="azure.signinlogs.resultType">0</field>
    <field name="azure.signinlogs.riskDetail" type="pcre2">(?:anomalousToken|tokenIssuerAnomaly|unfamiliarFeatures)</field>
    <description>SOaC: Suspicious authentication with anomalous token - possible AitM/EvilProxy phishing</description>
    <mitre>
      <id>T1557.001</id>
      <id>T1539</id>
    </mitre>
    <options>no_full_log</options>
    <group>credential,aitm,phishing,</group>
  </rule>

  <rule id="100502" level="13">
    <if_sid>87801</if_sid>
    <field name="azure.signinlogs.resultType" type="pcre2">(?:500121|50074)</field>
    <frequency>5</frequency>
    <timeframe>600</timeframe>
    <description>SOaC: MFA fatigue attack detected - multiple push notification denials</description>
    <mitre>
      <id>T1621</id>
    </mitre>
    <options>no_full_log</options>
    <group>credential,mfa_fatigue,</group>
  </rule>

  <rule id="100503" level="15">
    <if_sid>100502</if_sid>
    <field name="azure.signinlogs.resultType">0</field>
    <description>SOaC: MFA fatigue SUCCESS - user approved push after multiple denials, account likely compromised</description>
    <mitre>
      <id>T1621</id>
      <id>T1078</id>
    </mitre>
    <options>no_full_log</options>
    <group>credential,mfa_bypass,compromise,</group>
  </rule>

  <rule id="100504" level="14">
    <if_sid>87802</if_sid>
    <field name="o365.Operation" type="pcre2">(?:New-InboxRule|Set-InboxRule|UpdateInboxRules|New-TransportRule)</field>
    <description>SOaC: Post-phishing email rule creation - possible account takeover activity</description>
    <mitre>
      <id>T1114.003</id>
      <id>T1564.008</id>
    </mitre>
    <options>no_full_log</options>
    <group>credential,account_takeover,email,</group>
  </rule>

</group>
