{
  "name": "EvilProxy Credential Harvest Incident Response",
  "version": "1.0.0",
  "trigger": {"type": "alert", "source": ["Microsoft Sentinel", "CrowdStrike Identity"], "conditions": {"alert_name_pattern": "*evilproxy*|*aitm*|*mfa_fatigue*|*credential_harvest*", "severity": ["critical", "high"]}},
  "phases": [
    {"name": "Triage", "steps": [
      {"action": "enrich_identity", "source": "Azure AD", "parameters": {"include": ["risk_score", "recent_signins", "mfa_methods"]}},
      {"action": "check_phishing_infrastructure", "source": "URLhaus", "parameters": {"lookup": "sign_in_source_ip"}}
    ]},
    {"name": "Containment", "steps": [{"action": "execute_playbook", "playbook": "contain-credential-harvest-and-ato", "wait_for_completion": true}]},
    {"name": "Investigation", "steps": [
      {"action": "trace_phishing_email", "source": "Exchange Online", "parameters": {"find_original_phish": true}},
      {"action": "identify_all_victims", "parameters": {"check_similar_signin_patterns": true}},
      {"action": "timeline_builder", "sources": ["signin_logs", "audit_logs", "email_activity"]}
    ]},
    {"name": "Remediation", "steps": [
      {"action": "block_phishing_urls", "parameters": {"add_to_tenant_blocklist": true}},
      {"action": "deploy_phishing_resistant_mfa", "scope": "organization"},
      {"action": "enable_token_protection", "scope": "conditional_access"}
    ]},
    {"name": "Post-Incident", "steps": [
      {"action": "generate_report", "template": "credential_harvest_report"},
      {"action": "phishing_simulation", "parameters": {"type": "consent_phishing", "target": "affected_department"}}
    ]}
  ],
  "sla": {"session_revocation": "5m", "password_reset": "15m", "full_containment": "30m"}
}
