let RMM = DeviceProcessEvents
| where FileName in ("AnyDesk.exe","TeamViewer.exe","ScreenConnect.exe")
| summarize by AccountName;

let Risky = SigninLogs
| where RiskLevelDuringSignIn in ("medium","high")
| summarize by UserPrincipalName;

RMM
| join kind=inner Risky on $left.AccountName == $right.UserPrincipalName
| extend AlertReason="RMM execution combined with risky identity sign-in"
