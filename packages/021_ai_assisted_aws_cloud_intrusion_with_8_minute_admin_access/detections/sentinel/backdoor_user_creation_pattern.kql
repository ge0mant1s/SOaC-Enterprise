AWSCloudTrail | where EventName in ('CreateUser', 'CreateAccessKey', 'AttachUserPolicy', 'CreateLoginProfile') | extend UserName = tostring(RequestParameters.userName) | summarize BackdoorActions = count(), ActionTypes = make_set(EventName) by SourceIPAddress, UserIdentity_principalId, UserName, bin(TimeGenerated, 20m) | where BackdoorActions >= 3 and array_length(ActionTypes) >= 2