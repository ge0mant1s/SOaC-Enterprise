let CredDiscovery = AWSCloudTrail | where EventName in ('GetObject', 'ListObjects') and (RequestParameters contains '.aws' or RequestParameters contains 'credentials') | project TimeGenerated, SourceIPAddress, UserIdentity_principalId, Stage = 'CredDiscovery'; let Reconnaissance = AWSCloudTrail | where EventName in ('DescribeInstances', 'ListBuckets', 'ListRoles') | summarize by TimeGenerated, SourceIPAddress, UserIdentity_principalId | project TimeGenerated, SourceIPAddress, UserIdentity_principalId, Stage = 'Reconnaissance'; let PrivEsc = AWSCloudTrail | where EventName in ('CreateAccessKey', 'AttachUserPolicy') | project TimeGenerated, SourceIPAddress, UserIdentity_principalId, Stage = 'PrivilegeEscalation'; union CredDiscovery, Reconnaissance, PrivEsc | summarize Stages = make_set(Stage), StageCount = dcount(Stage), EventSpan = max(TimeGenerated) - min(TimeGenerated) by SourceIPAddress, UserIdentity_principalId | where StageCount >= 2 and EventSpan <= 30m