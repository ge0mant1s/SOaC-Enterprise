# ---
# id: SOAC-DET-001-221
# name: Endpoint precursors to token theft (browser store access + LOLBins)
# platform: crowdstrike_logscale
# mitre_attack: T1552
# severity: Medium
# ---

# Adapt field names to Falcon process events.
ProcessName in ["powershell.exe","cmd.exe","rundll32.exe","wscript.exe","cscript.exe"]
| where CommandLine=/Login Data|Web Data|Cookies|Local State/i
| groupBy([ComputerName, UserName, ProcessName], function=[count(), collect(CommandLine, limit=5)])
